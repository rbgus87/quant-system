# KRX Open API (https://openapi.krx.co.kr 가입 후 인증키 발급)
KRX_OPENAPI_KEY=your_krx_api_key_here

# 키움 REST API
KIWOOM_APP_KEY=your_appkey_here
KIWOOM_APP_SECRET=your_secretkey_here
KIWOOM_ACCOUNT_NO=1234567890

# 실전/모의 구분 (반드시 True로 시작)
IS_PAPER_TRADING=True

# 텔레그램
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# DART OpenAPI (https://opendart.fss.or.kr 인증키 발급)
DART_API_KEY=your_dart_api_key_here

# 내부 경로
DB_PATH=data/quant.db
LOG_PATH=logs/quant.log
